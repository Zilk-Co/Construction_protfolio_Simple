{
  "buildCommand": "pnpm --filter @workspace/zmco-website... run build",
  "outputDirectory": "artifacts/zmco-website/dist/public",
  "framework": null,
  "installCommand": "pnpm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://construction-portfolio-api-simple.onrender.com/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
